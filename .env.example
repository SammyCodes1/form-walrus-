# API Gateway
PORT=4000

# Sui Config
SUI_NETWORK=mainnet
SUI_RPC_URL=https://fullnode.mainnet.sui.io:443

# Walrus — server-side SDK pays WAL + SUI from this keypair.
# Format: suiprivkey1... (Bech32, as emitted by `sui keytool export`).
# Fund the corresponding address with WAL (storage) and SUI (gas).
WALRUS_SIGNER_PRIVKEY=

# Optional — offload sliver fan-out to an upload relay.
# Leave empty to talk directly to storage nodes.
WALRUS_UPLOAD_RELAY=

# Contract Deployments (Filled by deploy.sh)
PACKAGE_ID=
FORM_REGISTRY_ID=
